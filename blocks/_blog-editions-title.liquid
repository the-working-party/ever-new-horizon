{%- doc -%}
  Blog Editions Title Block

  Renders a header row with title on left and "View All" link on right.
  Used as the header for the Blog Editions section.

  Block receives:
  - block.settings: All configured settings from the schema
  - section.settings.blog: The parent section's blog setting

  @example
  {% content_for 'block', type: '_blog-editions-title', id: 'blog-editions-title' %}
{%- enddoc -%}

{% liquid
  if closest.blog != blank
    assign blog = closest.blog
  elsif section.settings.blog != blank
    assign blog = section.settings.blog
  endif

  assign blog_title = blog.title | default: 'Blog'
  assign blog_url = blog.url | default: '/blogs/news'

  # Build the display title
  if block.settings.text != blank
    assign display_title = block.settings.text
  else
    assign display_title = block.settings.prefix | append: ' — ' | append: blog_title | upcase
  endif
%}

<div
  class="blog-editions-header spacing-style"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  <div class="blog-editions-header__title">
    <span class="blog-editions-header__title-text {{ block.settings.type_preset }}">
      {{ display_title }}
    </span>
  </div>

  {% if block.settings.show_view_all and blog_url %}
    <a
      href="{{ blog_url }}"
      class="blog-editions-header__link"
    >
      {{ block.settings.view_all_text }}
    </a>
  {% endif %}
</div>

{% stylesheet %}
  .blog-editions-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--gap-md);
  }

  .blog-editions-header__title-text {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.25px;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
  }

  .blog-editions-header__link {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.25px;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    transition: text-decoration-thickness var(--duration-short) ease;
  }

  .blog-editions-header__link:hover {
    text-decoration-thickness: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.title",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "prefix",
      "label": "t:settings.prefix",
      "default": "BLOG"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:settings.custom_title",
      "info": "t:info.overrides_auto_title"
    },
    {
      "type": "header",
      "content": "t:content.view_all_link"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:settings.show_view_all",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "t:settings.view_all_text",
      "default": "View all",
      "visible_if": "{{ block.settings.show_view_all }}"
    },
    {
      "type": "header",
      "content": "t:content.typography"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
      "options": [
        {
          "value": "",
          "label": "t:options.default"
        },
        {
          "value": "h6",
          "label": "t:options.h6"
        }
      ],
      "default": "",
      "info": "t:info.edit_presets_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ]
}
{% endschema %}
