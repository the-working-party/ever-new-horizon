{%- doc -%}
  Renders the blog article image block for use within blog editions cards.

  @param {object} image - The image object
  @param {string} parent_block_id - The block.id of the parent blog post card
  @param {string} card_style - 'horizontal' or 'vertical' from parent card
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign image_resource = image
  assign card_style = card_style | default: 'vertical'

  # Calculate aspect ratio based on card style or explicit setting
  # Horizontal cards: square (1:1) works best with 50/50 split
  # Vertical cards: portrait (4:5) matches the Figma design
  assign ratio = 1
  case block_settings.image_ratio
    when 'landscape'
      assign ratio = '16 / 9'
    when 'portrait'
      assign ratio = '4 / 5'
    when 'square'
      assign ratio = '1 / 1'
    when 'adapt'
      # Auto: use card style to determine best ratio
      if card_style == 'horizontal'
        assign ratio = '1 / 1'
      else
        assign ratio = '4 / 5'
      endif
  endcase

  if ratio == 0 or ratio == null
    assign ratio = 1
  endif

  # Generate responsive image attributes
  assign sizes = '(min-width: 750px) 50vw, 100vw'
  assign widths = '240, 352, 832, 1200, 1600, 1920, 2560, 3840'

  # Calculate placeholder variant from parent block ID
  assign placeholder_prefix = 'blog-apparel-'
  assign placeholder_variants = 3
  assign block_parts = parent_block_id | split: '-'
  assign content_index = block_parts.last | default: 0
  assign variant = content_index | modulo: placeholder_variants | plus: 1
  assign placeholder_name = placeholder_prefix | append: variant
%}

{% style %}
  .blog-editions-card[data-block-id="{{ parent_block_id }}"] {
    --ratio: {{ ratio }};
  }
{% endstyle %}

{% if image_resource != blank %}
  <div
    class="
      image-block
      blog-editions-card__image
      spacing-style border-style
    "
    style="
      {%- render 'spacing-style', settings: block_settings -%}
      {%- render 'border-override', settings: block_settings -%}
    "
    {{ block.shopify_attributes }}
  >
    {{
      image_resource
      | image_url: width: 3840
      | image_tag: widths: widths, class: 'image-block__image', sizes: sizes, loading: 'lazy'
    }}
  </div>
{% else %}
  <div
    class="
      image-block
      blog-editions-card__image blog-editions-card__image--placeholder
      spacing-style border-style
    "
    style="
      {%- render 'spacing-style', settings: block_settings -%}
      {%- render 'border-override', settings: block_settings -%}
    "
    {{ block.shopify_attributes }}
  >
    <div class="image-block__image">
      {{ placeholder_name | placeholder_svg_tag: 'blog-placeholder-svg' }}
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .blog-editions-card__image {
    position: relative;
    display: flex;
    width: 100%;
    height: 100%;
    z-index: var(--layer-base);
    overflow: hidden;
    max-width: 100%;
    max-height: 100%;
    aspect-ratio: var(--ratio, 1 / 1);
  }

  .blog-editions-card__image .image-block__image {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  .blog-editions-card__image .blog-placeholder-svg {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.image",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:settings.aspect_ratio",
      "info": "t:info.aspect_ratio_adjusted",
      "options": [
        {
          "value": "adapt",
          "label": "t:options.auto"
        },
        {
          "value": "portrait",
          "label": "t:options.portrait"
        },
        {
          "value": "square",
          "label": "t:options.square"
        },
        {
          "value": "landscape",
          "label": "t:options.landscape"
        }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
