                    "accordion_row_TwjUf4": {
                      "type": "_accordion-row",
                      "settings": {
                        "heading": "Can I change or cancel my order?",
                        "open_by_default": false,
                        "icon": "none",
                        "width": 20
                      },
                      "blocks": {
                        "text_gWmHMk": {
                          "type": "text",
                          "settings": {
                            "text": "<p>Once your order has been placed, we begin preparing it right away to ensure timely delivery. This means we’re unable to make changes or cancel your order.</p><p>If you need further assistance, our Customer Care team is here to help.</p>",
                            "width": "100%",
