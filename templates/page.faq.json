                      },
                      "blocks": {
                        "text_dKPz47": {
                          "type": "text",
                          "settings": {
                            "text": "<p>Once your order has been dispatched, you’ll receive a shipping confirmation email with a tracking link. You can use this link at any time to follow your order’s journey right to your door.<br/><br/></p>",
                            "width": "100%",
