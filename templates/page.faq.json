                      "blocks": {
                        "text_m7mX3K": {
                          "type": "text",
                          "settings": {
                            "text": "<p>At this time, gift cards are not available for purchase on our US site. If you’re looking for a thoughtful alternative, explore our latest collections to find something she’ll truly love.</p>",
