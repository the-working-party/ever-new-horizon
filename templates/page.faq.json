                        "open_by_default": false,
                        "icon": "none",
                        "width": 20
                      },
                      "blocks": {
                        "text_yAQhJ4": {
                          "type": "text",
                          "settings": {
                            "text": "<p>We understand that sometimes things don’t work out. We offer returns in line with our returns policy, provided items are in their original condition.For full details on how to return your item or request an exchange, please visit our returns page or reach out to our Customer Care team.</p>",
                            "width": "100%",
