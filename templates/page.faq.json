                      ]
                    },
                    "accordion_row_VxbTUn": {
                      "type": "_accordion-row",
                      "settings": {
                        "heading": "I love the styles, but I’m not sure what size to choose?",
                        "open_by_default": false,
                        "icon": "none",
                        "width": 20
                      },
                      "blocks": {
                        "text_3kqmhQ": {
                          "type": "text",
                          "settings": {
                            "text": "<p>Finding your perfect fit is easy with our True Fit size recommendation tool, available on selected product pages. Simply answer a few quick questions to receive personalised sizing guidance.You can also refer to our size guide and product fit notes for additional detail to help you feel confident in your choice.<br/></p>",
                            "width": "100%",
