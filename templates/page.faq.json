                      },
                      "blocks": {
                        "text_MbdrfG": {
                          "type": "text",
                          "settings": {
                            "text": "<p>We’re a global women’s fashion brand founded in Australia,known for creating timeless, feminine pieces designed to elevate your everyday and special moments.Our collections are thoughtfully designed with attention to detail, quality, and modern elegance - so you can feel confident, wherever you’re headed.</p>",
                            "width": "100%",
                            "max_width": "none",
