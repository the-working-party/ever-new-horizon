                    "accordion_row_iFYMdr": {
                      "type": "_accordion-row",
                      "settings": {
                        "heading": "I have returned an item, when can I expect my refund?",
                        "open_by_default": false,
                        "icon": "none",
                        "width": 20
                      },
                      "blocks": {
                        "text_3w749A": {
                          "type": "text",
                          "settings": {
                            "text": "<p>Returns typically take three to seven business days to arrive at our warehouse. Once received, your refund will be processed within seven business days.</p><p>You’ll receive a confirmation email as soon as your refund has been completed, with funds expected to appear in your account within three to five business days thereafter.</p>",
                            "width": "100%",
