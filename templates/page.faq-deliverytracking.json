                      "blocks": {
                        "text_3w749A": {
                          "type": "text",
                          "settings": {
                            "text": "<p>If you’re not available at the time of delivery, the courier may leave your parcel in a safe place or provide instructions for redelivery. This may vary depending on the carrier.<br/><br/></p>",
                            "width": "100%",
