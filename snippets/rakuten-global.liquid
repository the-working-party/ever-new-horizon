{% doc %}
  Renders the Rakuten Advertising global loader script (SPI v3.4.8, MID 115849).
  Reads/sets the Rakuten landing cookies used by the conversion Custom Pixel in Shopify admin.
  Gated by the `settings.rakuten_global_script_enabled` theme setting.

  @example
  {% if settings.rakuten_global_script_enabled %}
    {% render 'rakuten-global' %}
  {% endif %}
{% enddoc %}

<!-- START Rakuten Advertising Tracking -->
<script type="text/javascript">
  (function (url) {
    /*Tracking Bootstrap Set Up DataLayer objects/properties here*/
    window.rakutenDataLayer = false; // Set custom DataLayer name if 'DataLayer' conflicts
    var dln = window.rakutenDataLayer || 'DataLayer';
    if (!window[dln]) {
      window[dln] = {};
    }
    if (!window[dln].events) {
      window[dln].events = {};
    }
    window[dln].events.SPIVersion = window[dln].events.SPIVersion || 'v3.4.8';

    var loc,
      ct = document.createElement('script');
    ct.type = 'text/javascript';
    ct.async = true;
    ct.src = url;
    loc = document.getElementsByTagName('script')[0];
    loc.parentNode.insertBefore(ct, loc);
  })(document.location.protocol + '//tag.rmp.rakuten.com/115849.ct.js');
</script>
<!-- END Rakuten Advertising Tracking -->
