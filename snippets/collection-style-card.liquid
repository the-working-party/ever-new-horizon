{%- doc -%}
  Collection Style Card

  Renders a simplified collection card with image and uppercase title.
  Designed for the collection-style section with specific typography.

  @param {object} collection - The Shopify collection object
  @param {object} section - The parent section object

  @example
  {% render 'collection-style-card',
    collection: collection,
    section: section
  %}
{%- enddoc -%}

{%- liquid
  assign onboarding = false
  if collection == blank
    assign onboarding = true
  endif

  assign image_ratio = section.settings.image_ratio | default: 'portrait'
  assign title_gap = section.settings.title_gap | default: 16
-%}

<a
  class="collection-style-card"
  href="{{ collection.url | default: '#' }}"
  {% if onboarding %}aria-disabled="true"{% endif %}
  style="--collection-style-card-title-gap: {{ title_gap }}px;"
>
  <div class="collection-style-card__image">
    {%- if onboarding -%}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- elsif collection.image != blank -%}
      {{- collection.image | image_url: width: 448 | image_tag:
        loading: 'lazy',
        class: 'collection-style-card__img',
        widths: '224, 300, 400, 448, 600',
        sizes: '(max-width: 749px) 124px, 224px'
      -}}
    {%- elsif collection.products.first.featured_image != blank -%}
      {{- collection.products.first.featured_image | image_url: width: 448 | image_tag:
        loading: 'lazy',
        class: 'collection-style-card__img',
        widths: '224, 300, 400, 448, 600',
        sizes: '(max-width: 749px) 124px, 224px'
      -}}
    {%- else -%}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <p class="collection-style-card__title">
    {%- if onboarding -%}
      {{ 'onboarding.collection_title' | t }}
    {%- else -%}
      {{ collection.title }}
    {%- endif -%}
  </p>
</a>

{% stylesheet %}
  .collection-style-card {
    display: flex;
    flex-direction: column;
    gap: var(--collection-style-card-title-gap, 16px);
    text-decoration: none;
    color: inherit;
  }

  .collection-style-card__image {
    position: relative;
    width: 100%;
    aspect-ratio: 100 / 133;
    overflow: hidden;
    background-color: var(--color-background-secondary, #f5f5f5);
  }

  .collection-style-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-style-card__image .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-style-card__title {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: var(--font-body--weight, 400);
    line-height: 16px;
    letter-spacing: 0.25px;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  /* Mobile adjustments */
  @media screen and (width < 750px) {
    .collection-style-card {
      gap: var(--spacing-sm, 12px);
    }
  }
{% endstylesheet %}
